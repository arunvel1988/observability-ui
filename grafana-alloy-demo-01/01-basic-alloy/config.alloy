otelcol.receiver.otlp "flask" {


 grpc {
   endpoint = "0.0.0.0:4317"
 }


 output {

   traces = [
    otelcol.processor.batch.default.input
   ]

 }

}



otelcol.processor.batch "default" {


 output {

   traces = [
    otelcol.exporter.logging.demo.input
   ]

 }

}



otelcol.exporter.logging "demo" {

 verbosity = "detailed"

}
